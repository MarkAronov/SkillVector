{
	"version": 2,
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"installCommand": "bun install",

	"functions": {
		"api/index.ts": {
			"maxDuration": 60
		}
	},

	"routes": [{ "src": "/(.*)", "dest": "/api/index.ts" }],

	"env": {
		"SKIP_STATIC_DATA": "true",
		"NODE_ENV": "production"
	}
}
